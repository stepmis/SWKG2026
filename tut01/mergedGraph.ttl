    dbo:runtime 140 ;
    dbo:sequel dbr:The_Dark_Knight ;
    dbo:starring dbr:Christian_Bale,
        dbr:Michael_Caine ;
    ex:hasTheme dbr:Vigilantism ;
    ex:playsIn dbr:Gotham_City .

dbr:Die_Hard rdfs:label "Stirb langsam"@de,
        "Die Hard"@en,
        "Міцний горішок"@ua ;
    ex:releaseDateUSA "1988-07-22"^^xsd:date .

