    dbo:producer dbr:Emma_Thomas ;
    dbo:runtime 152 ;
    dbo:starring dbr:Christian_Bale,
        dbr:Heath_Ledger ;
    ex:cast [ a rdf:Bag ;
            rdf:_1 dbr:Christian_Bale ;
            rdf:_2 dbr:Heath_Ledger ;
