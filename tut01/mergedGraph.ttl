    dbo:awards dbr:MTV_Movie_Award ;
    ex:portrays dbr:Mary_Jane_Watson .

dbr:Laura_Ziskin a dbo:Producer .

dbr:Matthew_McConaughey a dbo:Actor .

dbr:Sam_Raimi a dbo:Director ;
    dbo:awards dbr:Saturn_Award .

dbr:The_Dark_Knight a dbo:Film ;
    rdfs:label "The Dark Knight"@de,
        "The Dark Knight"@en ;
    dbo:director dbr:Christopher_Nolan ;
