    dbo:awards dbr:BAFTA_Award_for_Best_Direction .

dbr:Emma_Thomas a dbo:Producer .

[] a rdf:Statement ;
    ex:comment "The performance would have made Ledger a legend even if he had lived." ;
    ex:source dbr:The_Village_Voice ;
    rdf:object dbr:Legendary_Performance ;
    rdf:predicate ex:performance ;
    rdf:subject dbr:Heath_Ledger .

